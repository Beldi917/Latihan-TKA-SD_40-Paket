// ===============================================================
// Assumed Data Model
// ===============================================================
//
// Collection: tokens
// Document ID: tokenString (uppercase)
// Fields:
//   - id: string (required) - The token string
//   - used: boolean (required) - Whether the token has been used
//   - usedBy: string (optional) - The UID of the user who used this token
//   - createdAt: timestamp (optional) - Creation time
//
// Collection: users
// Document ID: userId (UID)
// Fields:
//   - uid: string (required) - The user's UID
//   - name: string (required) - The user's name
//   - token: string (required) - The token used for registration
//   - createdAt: timestamp (optional) - Registration time
//
// ===============================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "beldi2478@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidToken(data) {
      return data.keys().hasAll(['id', 'used']) &&
             data.id is string &&
             data.used is bool;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'name', 'token']) &&
             data.uid is string &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.token is string;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /tokens/{tokenId} {
      // Admin can do anything
      allow read, write: if isAdmin();
      
      // Users can read tokens to check if they are valid/used
      allow get: if isAuthenticated();
      
      // Users can update a token to mark it as used when registering
      allow update: if isAuthenticated() && 
                    !resource.data.used && 
                    request.resource.data.used == true &&
                    request.resource.data.usedBy == request.auth.uid &&
                    request.resource.data.diff(resource.data).affectedKeys().hasOnly(['used', 'usedBy']);
    }

    match /users/{userId} {
      // Admin can do anything
      allow read, write: if isAdmin();
      
      // Users can read their own profile
      allow read: if isOwner(userId);
      
      // Users can create their own profile if they have a valid token
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      
      // Users can update their own profile (but not their token or uid)
      allow update: if isOwner(userId) && 
                    isValidUser(request.resource.data) &&
                    request.resource.data.uid == resource.data.uid &&
                    request.resource.data.token == resource.data.token;
    }

    match /scores/{scoreId} {
      // Admin can do anything
      allow read, write: if isAdmin();
      
      // Users can read any score (for leaderboard)
      allow read: if isAuthenticated();
      
      // Users can create their own scores
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
    }
  }
}
